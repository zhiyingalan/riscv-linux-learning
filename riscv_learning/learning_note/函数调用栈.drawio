        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-23" value="s_ra:&lt;br style=&quot;font-size: 12px;&quot;&gt;保存函数返回后的执行指令地址" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="380" y="-120" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-24" value="当前FP保存在s0寄存器中，其值为栈底地址，也即父函数栈中的SP值。&lt;br style=&quot;font-size: 12px;&quot;&gt;s0寄存器保存在子函数s_fp位置&lt;br&gt;SP为栈顶地址，s_ra和s_fp为栈帧地址中保持的值" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="380" y="-5" width="390" height="55" as="geometry" />
        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-29" value="栈大小：&lt;br&gt;sp - 16" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="70" y="62.5" width="50" height="35" as="geometry" />
        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-30" value="栈大小：&lt;br&gt;sp - 32" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#FF0000;" parent="1" vertex="1">
          <mxGeometry x="70" y="175" width="50" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-31" value="&lt;font color=&quot;#ff0000&quot;&gt;int func2(int a, int b)&lt;br&gt;{&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; return a + b;&lt;br&gt;}&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;void func1(void)&lt;br&gt;{&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; func2(1, 2);&lt;br&gt;}&lt;br&gt;&lt;br&gt;void func0(void)&lt;br&gt;{&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;	&lt;/span&gt;int a = 10, b = 20;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;	&lt;/span&gt;func1();&lt;br&gt;}" style="text;whiteSpace=wrap;html=1;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="-140" y="-50" width="140" height="260" as="geometry" />
        </mxCell>
        <mxCell id="t0TYUXZwZ3TLBJUk_xWt-32" value="若为叶函数，则无需保存ra，因为不会被修改" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
